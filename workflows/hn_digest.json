{
  "name": "hn_digest",
  "description": "Daily AI news digest with fresh results every day",
  "nodes": [
    {
      "id": "fetch_news",
      "type": "scrape",
      "config": {
        "query": "AI startup funding news {today}",
        "num_results": 5,
        "output_key": "raw_text"
      }
    },
    {
      "id": "summarize",
      "type": "ai",
      "config": {
        "prompt": "You are a tech analyst. Summarize the following news articles in 5 clear bullet points. Focus on key developments, companies, and trends.\n\nArticles:\n{input}",
        "input_key": "raw_text",
        "output_key": "summary"
      }
    },
    {
      "id": "score_relevance",
      "type": "ai",
      "config": {
        "prompt": "Rate the following summary relevance to AI/ML engineering on a scale of 1-10. Format exactly like this:\nSCORE: X/10\nREASON: your reason here\n\nSummary:\n{input}",
        "input_key": "summary",
        "output_key": "relevance_score"
      }
    },
    {
      "id": "quality_check",
      "type": "filter",
      "config": {
        "condition": "min_length",
        "input_key": "summary",
        "min_length": 100
      }
    },
    {
      "id": "format_output",
      "type": "transform",
      "config": {
        "operation": "prefix",
        "input_key": "summary",
        "output_key": "final_report",
        "prefix": "=== FlowForge AI Digest ===\n\n"
      }
    },
    {
      "id": "send_email",
      "type": "email",
      "config": {
        "to": "sanjanareddy2607@gmail.com",
        "subject": "FlowForge Daily AI Digest",
        "input_key": "final_report"
      }
    }
  ]
}